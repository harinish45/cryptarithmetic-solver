{
    "name": "@cryptarithmetic/electron-app",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "dev": "npm run dev:api & npm run dev:renderer",
        "dev:renderer": "vite",
        "dev:api": "tsx --watch --env-file=.env server.ts",
        "build": "npm run build:renderer && npm run build:api",
        "build:renderer": "vite build",
        "build:api": "tsc -p tsconfig.server.json",
        "start": "NODE_ENV=production node dist/server.js",
        "start:dev": "tsx server.ts"
    },
    "dependencies": {
        "@cryptarithmetic/shared": "1.0.0",
        "@cryptarithmetic/solver-core": "1.0.0",
        "@google/adk": "^0.4.0",
        "cors": "^2.8.5",
        "dotenv": "^17.3.1",
        "express": "^4.21.0",
        "react": "^18.3.0",
        "react-dom": "^18.3.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.0",
        "@types/node": "^20.11.0",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "@vercel/node": "^5.6.11",
        "@vitejs/plugin-react": "^4.3.0",
        "tsx": "^4.21.0",
        "typescript": "^5.4.0",
        "vite": "^5.4.0"
    }
}