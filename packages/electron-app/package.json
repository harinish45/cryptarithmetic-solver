{
    "name": "@cryptarithmetic/electron-app",
    "version": "1.0.0",
    "private": true,
    "main": "dist/main/main.js",
    "scripts": {
        "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
        "dev:renderer": "vite",
        "dev:electron": "tsc -p tsconfig.main.json && electron .",
        "build": "tsc -p tsconfig.main.json && vite build",
        "start": "electron ."
    },
    "dependencies": {
        "@cryptarithmetic/shared": "1.0.0",
        "@cryptarithmetic/solver-core": "1.0.0",
        "react": "^18.3.0",
        "react-dom": "^18.3.0"
    },
    "devDependencies": {
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.3.0",
        "concurrently": "^8.2.0",
        "electron": "^31.0.0",
        "typescript": "^5.4.0",
        "vite": "^5.4.0"
    }
}