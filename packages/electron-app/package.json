{
    "name": "@cryptarithmetic/electron-app",
    "version": "1.0.0",
    "private": true,
    "main": "dist/main/main.js",
    "scripts": {
        "prebuild": "cd ../.. && npm run build:all",
        "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\" \"npm run dev:api\"",
        "dev:renderer": "vite",
        "dev:electron": "tsc -p tsconfig.main.json && electron .",
        "dev:api": "tsx --watch --env-file=.env local-api.ts",
        "build": "tsc -p tsconfig.main.json && vite build",
        "start": "electron ."
    },
    "dependencies": {
        "@cryptarithmetic/shared": "1.0.0",
        "@cryptarithmetic/solver-core": "1.0.0",
        "@google/adk": "^0.4.0",
        "dotenv": "^17.3.1",
        "react": "^18.3.0",
        "react-dom": "^18.3.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/body-parser": "^1.19.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "@vercel/node": "^5.6.11",
        "@vitejs/plugin-react": "^4.3.0",
        "body-parser": "^2.2.2",
        "concurrently": "^8.2.0",
        "cors": "^2.8.6",
        "electron": "^31.0.0",
        "express": "^5.2.1",
        "tsx": "^4.21.0",
        "typescript": "^5.4.0",
        "vite": "^5.4.0"
    }
}