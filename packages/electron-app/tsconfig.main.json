{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": [
            "ES2022"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "sourceMap": true,
        "outDir": "./dist/main",
        "rootDir": "./src/main"
    },
    "include": [
        "src/main/**/*"
    ],
    "references": [
        {
            "path": "../solver-core"
        },
        {
            "path": "../shared"
        }
    ]
}